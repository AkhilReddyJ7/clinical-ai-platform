APP_NAME="Clinical AI Intelligence Platform"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=true
LOG_LEVEL="INFO"

# Local/dev-only default credentials. Override via .env (gitignored) for
# anything beyond a local docker compose run — never commit real credentials.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clinical_ai
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/clinical_ai"

STORAGE_ROOT="./data/uploads"
MAX_UPLOAD_SIZE_BYTES=26214400
MAX_PDF_PAGES=50

# Comma-separated list of valid X-API-Key values, required on all
# /documents endpoints (not /health or /). Local/dev-only default below —
# generate real keys and set them via .env (gitignored) for anything beyond
# a local docker compose run; never commit real keys.
API_KEYS=local-dev-key

# Required for real LLM-based field extraction (AnthropicFieldExtractionPipeline).
# Empty by default — the pipeline fails closed (refuses to construct) rather
# than making a request with an invalid key. Get a key from
# https://console.anthropic.com/ and set it here or in a gitignored .env;
# never commit a real key. Tests and local `docker compose up` without this
# set still work via MockFieldExtractionPipeline.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_SECONDS=30.0
ANTHROPIC_MAX_INPUT_CHARS=12000
